# Copy to `.env` and fill in. The app loads `.env` automatically (python-dotenv).
# NOTE: `.env` is gitignored; this template (.env.example) is committed — never put a
# real key here.

# Required: used by the Anthropic SDK for document generation.
ANTHROPIC_API_KEY=

# Vector store backend. "memory" (default) = zero setup, no Docker/Postgres.
# "postgres" = pgvector (the brief's vector DB; needs `docker compose up -d db`
# or a native Postgres). Leave as memory for the minimal path.
VECTOR_BACKEND=memory

# Used only when VECTOR_BACKEND=postgres. Matches docker-compose.yml.
DATABASE_URL=postgresql://cv:cv@localhost:5432/community_voices

# The community we ingest (any text-rich, active subreddit works).
SUBREDDIT=japanweather

# Generation model. Defaults to claude-opus-4-8 (best document quality, ~$0.15-0.30
# per A/B run). For near-free iteration while testing the plumbing, set:
#   GEN_MODEL=claude-haiku-4-5
# Switch back to claude-opus-4-8 for the real demo.
# GEN_MODEL=claude-opus-4-8
